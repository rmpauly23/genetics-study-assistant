# ── Anthropic ──────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth2 ──────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: https://<your-app>.streamlit.app  (and localhost:8501 for local dev)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Redirect URI ───────────────────────────────────────────────────────────
# Must exactly match the URI configured in Google Cloud Console
# For local dev: http://localhost:8501
# For Streamlit Cloud: https://<your-username>-<repo-name>-<branch>-<hash>.streamlit.app
GOOGLE_REDIRECT_URI=http://localhost:8501

# ── App password ───────────────────────────────────────────────────────────
# Simple shared password to gate access to the app
APP_PASSWORD=changeme
